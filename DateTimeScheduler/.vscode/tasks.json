{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Scheduler",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "-g",
        "main.cpp",
        "DateTime.cpp",
        "Event.cpp",
        "Scheduler.cpp",
        "-o",
        "scheduler"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    }
  ]
}
